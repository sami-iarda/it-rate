# Copy this file to .env and fill in the real values.
# .env is gitignored and must never be committed.

# ---- SMTP -------------------------------------------------------------------
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_AUTH=true
SMTP_SECURE=tls
SMTP_TIMEOUT=30
SMTP_USERNAME=no-reply@example.com
SMTP_PASSWORD=
# 0=off, 1=client, 2=client+server, 3=detailed (logged via error_log)
SMTP_DEBUG=0

# For a local MailHog setup instead (http://127.0.0.1:8025):
#   SMTP_HOST=127.0.0.1
#   SMTP_PORT=1025
#   SMTP_AUTH=false
#   SMTP_SECURE=

# ---- Mail identity ----------------------------------------------------------
MAIL_FROM=no-reply@example.com
MAIL_FROM_NAME="نظام طلبات المشاريع التقنية"
ADMIN_MAIL_FROM_NAME="إدارة تقنية المعلومات"

# ---- IT owner (receives full request details) -------------------------------
IT_OWNER_EMAIL=it-owner@example.com
IT_OWNER_NAME="إدارة تقنية المعلومات"

# ---- Admin dashboard login --------------------------------------------------
# Generate the hash with:
#   php -r "echo password_hash('your-password', PASSWORD_BCRYPT, ['cost'=>12]);"
ADMIN_EMAIL=admin@example.com
ADMIN_PASS_HASH=

# ---- test_smtp.php only -----------------------------------------------------
TEST_RECIPIENT=you@example.com
